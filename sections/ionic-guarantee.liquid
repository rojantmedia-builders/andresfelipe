<style>
  .ionic-guarantee {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }
  .ionic-guarantee__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .ionic-guarantee__text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ionic-guarantee__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.15;
    margin: 0 0 30px;
    color: {{ section.settings.text_color }};
  }
  .ionic-guarantee__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .ionic-guarantee__list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: {{ section.settings.list_font_size }}px;
    font-weight: 700;
    color: {{ section.settings.text_color }};
    margin-bottom: 14px;
    line-height: 1.3;
  }
  .ionic-guarantee__list li::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ section.settings.text_color }};
    flex-shrink: 0;
  }
  .ionic-guarantee__image-col img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ section.settings.image_border_radius }}px;
    object-fit: cover;
  }
  .ionic-guarantee__image-col {
    overflow: hidden;
    border-radius: {{ section.settings.image_border_radius }}px;
  }
  @media (max-width: 768px) {
    .ionic-guarantee__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .ionic-guarantee__heading {
      font-size: {{ section.settings.heading_size | times: 0.65 | round }}px;
    }
    .ionic-guarantee__image-col {
      order: -1;
    }
  }
</style>

<div class="ionic-guarantee">
  <div class="ionic-guarantee__inner">

    <div class="ionic-guarantee__text-col">
      {%- if section.settings.heading != blank -%}
        <h2 class="ionic-guarantee__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="ionic-guarantee__list">
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.item }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="ionic-guarantee__image-col">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy">
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Ionic – Guarantee",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "RESPIRARÁS MEJOR, Y LO GARANTIZAMOS"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (foto de pareja / producto)"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (desktop)",
      "min": 20,
      "max": 72,
      "step": 2,
      "default": 44,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "list_font_size",
      "label": "List item font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 18,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Elemento de lista",
      "settings": [
        {
          "type": "text",
          "id": "item",
          "label": "Texto del elemento",
          "default": "Beneficio del producto"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ionic – Guarantee",
      "blocks": [
        { "type": "bullet", "settings": { "item": "100% Sin riesgo" } },
        { "type": "bullet", "settings": { "item": "Garantía de devolución de dinero" } },
        { "type": "bullet", "settings": { "item": "Garantía del fabricante por 2 años" } },
        { "type": "bullet", "settings": { "item": "Recomendado para alergias" } }
      ]
    }
  ]
}
{% endschema %}
