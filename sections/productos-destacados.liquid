{{ 'featured-collection.css' | asset_url | stylesheet_tag }}
{{ 'product-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign coleccion        = collections[section.settings.coleccion]
  assign columnas         = section.settings.columnas_desktop
  assign columnas_mobile  = section.settings.columnas_mobile
  assign usar_bloques     = false

  if section.blocks.size > 0
    assign usar_bloques = true
  endif

  unless usar_bloques
    assign limite = section.settings.limite
    if limite < 1
      assign limite = 3
    endif
  endunless
-%}

<div class="featured-collection section-spacing" style="--fc-columns: {{ columnas }}; --fc-columns-mobile: {{ columnas_mobile }};">
  <div class="row">
    <div class="small-12 columns">

      <div class="section-header">
        <div class="section-header--content">
          {%- if section.settings.titulo != blank -%}
            <h3 class="section-header--title">{{ section.settings.titulo }}</h3>
          {%- endif -%}
          {%- if section.settings.descripcion != blank -%}
            <div class="section-header--description rte">{{ section.settings.descripcion }}</div>
          {%- endif -%}
        </div>

        {%- if section.settings.mostrar_boton and section.settings.texto_boton != blank and coleccion != blank -%}
          <div class="section-header--button">
            <a
              href="{{ coleccion.url }}"
              title="{{ section.settings.texto_boton | escape }}"
              role="link"
              class="text-button{% if section.settings.boton_con_icono %} text-button--has-icon{% endif %}"
            >
              {{ section.settings.texto_boton }}
              {%- if section.settings.boton_con_icono -%}
                <span>
                  <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L5 5L1 9" stroke="var(--color-accent)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              {%- endif -%}
            </a>
          </div>
        {%- endif -%}
      </div>

      <div class="featured-collection__inner display-type--grid">
        <div id="product-grid-{{ section.id }}" class="products row grid">

          {%- if usar_bloques -%}
            {%- for block in section.blocks -%}
              {%- assign producto_bloque = all_products[block.settings.producto] -%}
              {%- if producto_bloque != blank -%}
                <div class="small-6 medium-4 columns" {{ block.shopify_attributes }}>
                  {%- render 'product-card',
                    product:                  producto_bloque,
                    imagen_custom:            block.settings.imagen,
                    imagen_secundaria_custom: block.settings.imagen_secundaria
                  -%}
                </div>
              {%- endif -%}
            {%- endfor -%}

          {%- elsif coleccion != blank and coleccion.products_count > 0 -%}
            {%- for product in coleccion.products limit: limite -%}
              <div class="small-6 medium-4 columns">
                {%- render 'product-card', product: product -%}
              </div>
            {%- endfor -%}

          {%- else -%}
            {%- for i in (1..limite) -%}
              <div class="small-6 medium-4 columns">
                <div class="product-card text-left product-card--content-spacing-false product-card--border-false has-shadow--false">
                  <figure class="product-featured-image">
                    <div class="product-featured-image-link aspect-ratio aspect-ratio--adapt" style="--padding-bottom: 100%; background: rgba(0,0,0,0.05);"></div>
                  </figure>
                  <div class="product-card-info">
                    <span class="price"><ins><span class="amount"><span class="from">Desde</span> <span class="money">$0</span></span></ins></span>
                    <span class="product-card-title">Producto</span>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Productos destacados",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "titulo",
      "label": "Título",
      "default": "Productos destacados"
    },
    {
      "type": "richtext",
      "id": "descripcion",
      "label": "Descripción",
      "default": "<p>Agrega una colección o añade tarjetas manualmente.</p>"
    },
    {
      "type": "header",
      "content": "Colección automática"
    },
    {
      "type": "paragraph",
      "content": "Se usa solo si no hay tarjetas de producto añadidas manualmente."
    },
    {
      "type": "collection",
      "id": "coleccion",
      "label": "Colección"
    },
    {
      "type": "range",
      "id": "limite",
      "label": "Cantidad de productos (colección)",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Botón de colección"
    },
    {
      "type": "checkbox",
      "id": "mostrar_boton",
      "label": "Mostrar botón",
      "default": true
    },
    {
      "type": "text",
      "id": "texto_boton",
      "label": "Texto del botón",
      "default": "Ver colección"
    },
    {
      "type": "checkbox",
      "id": "boton_con_icono",
      "label": "Botón con ícono",
      "default": true
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "range",
      "id": "columnas_desktop",
      "label": "Columnas (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columnas_mobile",
      "label": "Columnas (mobile)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Tarjeta de producto",
      "settings": [
        {
          "type": "product",
          "id": "producto",
          "label": "Producto"
        },
        {
          "type": "image_picker",
          "id": "imagen",
          "label": "Imagen principal",
          "info": "Opcional. Reemplaza la imagen principal del producto."
        },
        {
          "type": "image_picker",
          "id": "imagen_secundaria",
          "label": "Imagen de hover",
          "info": "Opcional. Se muestra al pasar el cursor por encima."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Productos destacados",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
