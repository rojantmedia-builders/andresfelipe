{% comment %} ba-16458924 + ba-16458926 – zpa-html-block-117 {% endcomment %}

<style>
  .ionic-html-block {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }
  .ionic-html-block__inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  } 

  /* Tabla de comparación */
  .ionic-html-block__inner table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .ionic-html-block__inner table th,
  .ionic-html-block__inner table td {
    padding: 12px 16px;
    text-align: center;
    border-bottom: 1px solid #e5e5e5;
  }
  .ionic-html-block__inner table th {
    font-weight: 900;
    background: #1a1a1a;
    color: #fff;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .ionic-html-block__inner table tr:nth-child(even) td {
    background: #f9f9f9;
  }
  .ionic-html-block__inner table td:first-child {
    text-align: left;
    font-weight: 600;
  }

  /* Logos "Como se vio en" */
  .ionic-html-block__media-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 32px;
  }
  .ionic-html-block__media-logos img {
    height: 32px;
    width: auto;
    opacity: 0.6;
    filter: grayscale(100%);
    transition: opacity 0.2s;
  }
  .ionic-html-block__media-logos img:hover {
    opacity: 1;
    filter: none;
  }
  .ionic-html-block__media-title {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #999;
    margin: 0 0 24px;
  }
</style>

<div class="ionic-html-block">
  <div class="ionic-html-block__inner">
    {%- if section.settings.html_content != blank -%}
      {{ section.settings.html_content }}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Ionic – Bloque HTML",
  "class": "index-section",
  "settings": [
    {
      "type": "html",
      "id": "html_content",
      "label": "Contenido HTML",
      "default": "<p class=\"ionic-html-block__media-title\">Como se vio en</p><div class=\"ionic-html-block__media-logos\"><span style=\"font-weight:900;font-size:1.1rem;letter-spacing:-0.02em;\">Forbes</span><span style=\"font-weight:900;font-size:1.1rem;\">CNN</span><span style=\"font-weight:900;font-size:1rem;\">NBC News</span><span style=\"font-weight:900;font-size:1rem;\">USA Today</span></div>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Ancho máximo",
      "min": 480, "max": 1200, "step": 40,
      "default": 960, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Relleno superior",
      "min": 0, "max": 120, "step": 4,
      "default": 48, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Relleno inferior",
      "min": 0, "max": 120, "step": 4,
      "default": 48, "unit": "px"
    }
  ],
  "presets": [
    { "name": "Ionic – Bloque HTML" }
  ]
}
{% endschema %}
