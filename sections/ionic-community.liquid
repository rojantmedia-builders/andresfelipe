{% comment %} ba-16458920 – zpa-plain-text-002 {% endcomment %}

<style>
  .ionic-community {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    text-align: center;
  }
  .ionic-community__inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }
  .ionic-community__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.15;
    letter-spacing: 0.01em;
    margin: 0 0 28px;
    color: {{ section.settings.text_color }};
  }
  .ionic-community__body {
    font-size: {{ section.settings.body_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 768px) {
    .ionic-community__heading {
      font-size: {{ section.settings.heading_size | times: 0.6 | round }}px;
    }
  }
</style>

<div class="ionic-community">
  <div class="ionic-community__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ionic-community__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="ionic-community__body">{{ section.settings.body }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Ionic – Community Text",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ÚNETE A MÁS DE 200.000 PERSONAS Y EMPIEZA A RESPIRAR MEJOR DESDE YA"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>El Iónico neutraliza los contaminantes dañinos liberando iones cargados negativamente al aire. Estos se adhieren a agentes contaminantes como virus, bacterias, polvo y humo, eliminándolos del ambiente y brindándote un entorno de respiración más saludable.</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Max content width",
      "min": 480,
      "max": 1200,
      "step": 40,
      "default": 880,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size (desktop)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Ionic – Community Text"
    }
  ]
}
{% endschema %}
