{{ 'scrolling-text.css' | asset_url | stylesheet_tag }}

<div class="row full-width-row-full">
  <div class="small-12 columns">
    <div class="scrolling-text scrolling-text--full-width-{{ section.settings.full_width }} scrolling-text-uppercase--{{ section.settings.uppercase }} section-spacing{% if section.settings.disable_top_spacing %} section-spacing--disable-top{% endif %}{% if section.settings.disable_bottom_spacing %} section-spacing--disable-bottom{% endif %} {% if section.settings.use_heading_font %}heading-font{% else %}body-font{% endif %}" id="scrolling-text-{{ section.id }}" style="--color-bg:{{ section.settings.color_bg }};--color-text:{{ section.settings.color_text }};--overlay-color-rgb: {{ section.settings.overlay_color.red }},{{ section.settings.overlay_color.green }},{{ section.settings.overlay_color.blue }}; --overlay-opacity: {{ section.settings.overlay_opacity }}; --rotation: -{{ section.settings.rotation }}deg">
      <div class="scrolling-text--inner direction-{{ section.settings.direction }}" style="--marquee-speed: {{ section.settings.speed }}s; font-size: {{ section.settings.font_size }}px;">
        {%- if section.blocks.size > 0 -%}
          {%- for i in (1..section.settings.repeats) -%}
            <div>
              {%- for block in section.blocks -%}
                <div class="scrolling-text--item outline-text--{{ block.settings.outline_text }}" {{ block.shopify_attributes }}>
                  {%- if block.settings.link != blank -%}
                    <a class="scrolling-text--link" href="{{ block.settings.link }}">
                      {%- if block.settings.image != blank -%}
                        {%- capture scrolling_text_image_class -%}scrolling-text--image scrolling-text--image--{{ block.settings.image_size }}{%- endcapture -%}
                        {{ block.settings.image | image_url: width: 300, height: 120, crop: 'center' | image_tag: class: scrolling_text_image_class, widths: '100, 200, 300', sizes: '158px', loading: 'lazy', fetchpriority: 'auto' }}
                      {%- endif -%}
                      {%- if block.settings.text != blank -%}
                        <span>{{ block.settings.text }}</span>
                      {%- else -%}
                        <span></span>
                      {%- endif -%}
                    </a>
                  {%- else -%}
                    {%- if block.settings.image != blank -%}
                      <img
                        class="scrolling-text--image scrolling-text--image--{{ block.settings.image_size }}"
                        src="{{ block.settings.image | image_url: width: 300, height: 120, crop: 'center' }}"
                        srcset="{{ block.settings.image | image_url: width: 100, height: 120, crop: 'center' }} 100w, {{ block.settings.image | image_url: width: 200, height: 120, crop: 'center' }} 200w, {{ block.settings.image | image_url: width: 300, height: 120, crop: 'center' }} 300w"
                        sizes="158px"
                        loading="lazy"
                        alt="{{ block.settings.image.alt | escape }}"
                        style="object-position: 50% 50%;"
                        width="300"
                        height="120">
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <span>{{ block.settings.text }}</span>
                    {%- else -%}
                      <span></span>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Scrolling text",
  "tag": "section",
  "class": "section-scrolling-text",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase",
      "default": false
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Speed (seconds)",
      "min": 3,
      "max": 30,
      "step": 1,
      "default": 10
    },
    {
      "type": "range",
      "id": "repeats",
      "label": "Repeats (for continuous loop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 12,
      "max": 64,
      "step": 1,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "use_heading_font",
      "label": "Use heading font",
      "default": true
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background color",
      "default": "#2c2d2e"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text color",
      "default": "#1a1c1d"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0
    },
    {
      "type": "range",
      "id": "rotation",
      "label": "Rotation (deg)",
      "min": 0,
      "max": 15,
      "step": 1,
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "disable_top_spacing",
      "label": "Disable top spacing",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "disable_bottom_spacing",
      "label": "Disable bottom spacing",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_size",
          "label": "Image size",
          "default": "small",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Text"
        },
        {
          "type": "checkbox",
          "id": "outline_text",
          "label": "Outline text",
          "default": false
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrolling text",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
