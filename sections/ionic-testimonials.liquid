      "default": "Confiado por la gente, amado por los clientes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "4.8/5 en más de 4.579 reseñas"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Color de estrellas",
      "default": "#22c55e"
    },
    {
      "type": "range",
      "id": "heading_size",
