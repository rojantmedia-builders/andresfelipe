{% comment %} ba-16458923 – zpa-plain-text-002 {% endcomment %}

<style>
  .ionic-plain-text-2 {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    text-align: {{ section.settings.text_align }};
  } 
  .ionic-plain-text-2__inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  } 
  .ionic-plain-text-2__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 900;
    line-height: 1.15;
    margin: 0 0 20px;
    color: {{ section.settings.text_color }};
    {%- if section.settings.uppercase %}text-transform: uppercase;{%- endif %}
  }
  .ionic-plain-text-2__body {
    font-size: {{ section.settings.body_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.7;
    margin: 0;
  }
  .ionic-plain-text-2__body p { margin: 0 0 14px; }
  .ionic-plain-text-2__body p:last-child { margin-bottom: 0; }
  @media (max-width: 768px) {
    .ionic-plain-text-2__heading {
      font-size: {{ section.settings.heading_size | times: 0.65 | round }}px;
    }
  }
</style>

<div class="ionic-plain-text-2">
  <div class="ionic-plain-text-2__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ionic-plain-text-2__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="ionic-plain-text-2__body">{{ section.settings.body }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Ionic – Texto Simple 2",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "CÓMO FUNCIONA EL PURIFICADOR IÓNICO"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Título en mayúsculas",
      "default": true
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Texto del cuerpo",
      "default": "<p>Describe aquí el contenido de esta sección.</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alineación",
      "default": "center",
      "options": [
        { "value": "left",   "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right",  "label": "Derecha" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Ancho máximo",
      "min": 480, "max": 1200, "step": 40,
      "default": 880, "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño del título",
      "min": 20, "max": 80, "step": 2,
      "default": 44, "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Tamaño del texto",
      "min": 12, "max": 24, "step": 1,
      "default": 16, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Relleno superior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Relleno inferior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    }
  ],
  "presets": [
    { "name": "Ionic – Texto Simple 2" }
  ]
}
{% endschema %}
