{% comment %} ba-16458915 – zpa-plain-text-002 {% endcomment %}

<style>
  .ionic-title-banner {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    text-align: center;
  }
  .ionic-title-banner h2 {
    font-size: {{ section.settings.font_size }}px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin: 0;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
  }
  @media (max-width: 768px) {
    .ionic-title-banner h2 {
      font-size: {{ section.settings.font_size | times: 0.65 | round }}px;
    }
  }
  .index-section{
    margin:0px 0 !important;
  }
</style>

<div class="ionic-title-banner">
  <div class="page-width">
    <h2>{{ section.settings.title }}</h2>
  </div>
</div>

{% schema %}
{
  "name": "Ionic – Title Banner",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "TU NUEVO PURIFICADOR DE AIRE IÓNICO:"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Tamaño de fuente (escritorio)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 44,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Relleno superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Relleno inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 20,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Ionic – Banner Título"
    }
  ]
}
{% endschema %}
