{% comment %} ba-16459961 – zpa-bundle-with-radio-buttons-214 {% endcomment %}

{%- assign target_product = all_products[section.settings.product] -%}
{%- if target_product == empty -%}
  {%- assign target_product = product -%}
{%- endif -%}

<style>
  .ionic-bundle {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }
  .ionic-bundle__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .ionic-bundle__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 900;
    text-align: center;
    text-transform: uppercase;
    margin: 0 0 32px;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
  }
  /* Two-column layout */
  .ionic-bundle__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  /* Left: product image */
  .ionic-bundle__hero-img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    display: block;
    object-fit: cover;
  }
  .ionic-bundle__thumbs {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    overflow-x: auto;
  }
  .ionic-bundle__thumb {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    border: 2px solid transparent;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .ionic-bundle__thumb.is-active,
  .ionic-bundle__thumb:hover {
    border-color: {{ section.settings.selected_color }};
  }
  /* Right: variant cards */
  .ionic-bundle__options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 20px;
  }
  .ionic-bundle__option {
    border: 2px solid #e0e0e0;
    border-radius: 12px;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: #fff;
    position: relative;
    text-align: center;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .ionic-bundle__option:hover { border-color: #aaa; }
  .ionic-bundle__option.is-selected {
    border-color: {{ section.settings.selected_color }};
    box-shadow: 0 0 0 1px {{ section.settings.selected_color }};
  }
  .ionic-bundle__option input[type="radio"] { display: none; }
  .ionic-bundle__radio-wrap {
    padding: 12px 0 4px;
  }
  .ionic-bundle__radio {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid #ccc;
    margin: 0 auto;
    position: relative;
    transition: border-color 0.2s;
    display: block;
  }
  .ionic-bundle__option.is-selected .ionic-bundle__radio {
    border-color: {{ section.settings.selected_color }};
  }
  .ionic-bundle__option.is-selected .ionic-bundle__radio::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 10px; height: 10px;
    border-radius: 50%;
    background: {{ section.settings.selected_color }};
  }
  .ionic-bundle__option-img-wrap {
    background: #1a2235;
    padding: 12px;
    margin: 8px;
    border-radius: 8px;
  }
  .ionic-bundle__option-img {
    width: 100%;
    height: 80px;
    object-fit: contain;
    display: block;
  }
  .ionic-bundle__option-body {
    padding: 8px 8px 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  .ionic-bundle__option-title {
    font-weight: 700;
    font-size: 0.75rem;
    color: {{ section.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }
  .ionic-bundle__option-price-current {
    font-weight: 900;
    font-size: 1rem;
    color: {{ section.settings.sale_price_color }};
    display: block;
  }
  .ionic-bundle__option-price-compare {
    font-size: 0.75rem;
    color: #999;
    text-decoration: line-through;
    display: block;
  }
  .ionic-bundle__badge {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: {{ section.settings.badge_color }};
    color: {{ section.settings.badge_text_color }};
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    padding: 5px 8px;
    text-transform: uppercase;
    text-align: center;
    z-index: 1;
  }
  .ionic-bundle__badge ~ .ionic-bundle__radio-wrap {
    padding-top: 22px;
  }
  .ionic-bundle__cta {
    display: block;
    width: 100%;
    padding: 18px 24px;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text }};
    font-size: 1.05rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    text-align: center;
    transition: opacity 0.2s;
    margin-bottom: 14px;
  }
  .ionic-bundle__cta:hover { opacity: 0.88; }
  .ionic-bundle__guarantee {
    text-align: center;
    font-size: 0.82rem;
    color: #666;
  }
  @media (max-width: 768px) {
    .ionic-bundle__cols {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .ionic-bundle__heading {
      font-size: {{ section.settings.heading_size | times: 0.7 | round }}px;
    }
  }
  @media (max-width: 480px) {
    .ionic-bundle__options {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="ionic-bundle">
  <div class="ionic-bundle__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ionic-bundle__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ionic-bundle__cols">

      <!-- Left: product image + thumbnails -->
      <div class="ionic-bundle__img-col">
        {%- if section.settings.main_image != blank -%}
          <img id="ionic-bundle-hero-{{ section.id }}"
            class="ionic-bundle__hero-img"
            src="{{ section.settings.main_image | image_url: width: 800 }}"
            alt="{{ product.title }}"
            width="{{ section.settings.main_image.width }}"
            height="{{ section.settings.main_image.height }}"
            loading="lazy">
        {%- elsif target_product.featured_image != blank -%}
          <img id="ionic-bundle-hero-{{ section.id }}"
            class="ionic-bundle__hero-img"
            src="{{ target_product.featured_image | image_url: width: 800 }}"
            alt="{{ target_product.title }}"
            width="{{ target_product.featured_image.width }}"
            height="{{ target_product.featured_image.height }}"
            loading="lazy">
        {%- endif -%}

        <div class="ionic-bundle__thumbs" id="ionic-bundle-thumbs-{{ section.id }}">
          {%- for image in target_product.images limit: 6 -%}
            <img class="ionic-bundle__thumb{% if forloop.first %} is-active{% endif %}"
              src="{{ image | image_url: width: 144 }}"
              alt="{{ image.alt | default: target_product.title }}"
              width="72" height="72" loading="lazy"
              data-src="{{ image | image_url: width: 800 }}">
          {%- endfor -%}
        </div>
      </div>

      <!-- Right: variant selector + CTA -->
      <div class="ionic-bundle__picker">
        <form action="{{ routes.cart_add_url }}" method="post" id="ionic-bundle-form-{{ section.id }}">
          <div class="ionic-bundle__options" id="ionic-bundle-options-{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- assign variant = target_product.variants[forloop.index0] -%}
              <label
                class="ionic-bundle__option{% if forloop.first %} is-selected{% endif %}"
                for="ionic-bundle-{{ section.id }}-{{ forloop.index }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.badge != blank -%}
                  <span class="ionic-bundle__badge">{{ block.settings.badge }}</span>
                {%- endif -%}

                <input
                  type="radio"
                  id="ionic-bundle-{{ section.id }}-{{ forloop.index }}"
                  name="id"
                  value="{{ variant.id }}"
                  {% if forloop.first %}checked{% endif %}
                >
                <div class="ionic-bundle__radio-wrap">
                  <span class="ionic-bundle__radio"></span>
                </div>

                <div class="ionic-bundle__option-img-wrap">
                  {%- if block.settings.image != blank -%}
                    <img class="ionic-bundle__option-img"
                      src="{{ block.settings.image | image_url: width: 200 }}"
                      alt="{{ block.settings.title }}"
                      width="200" height="80" loading="lazy">
                  {%- elsif variant.featured_image != blank -%}
                    <img class="ionic-bundle__option-img"
                      src="{{ variant.featured_image | image_url: width: 200 }}"
                      alt="{{ block.settings.title }}"
                      width="200" height="80" loading="lazy">
                  {%- elsif target_product.featured_image != blank -%}
                    <img class="ionic-bundle__option-img"
                      src="{{ target_product.featured_image | image_url: width: 200 }}"
                      alt="{{ block.settings.title }}"
                      width="200" height="80" loading="lazy">
                  {%- endif -%}
                </div>

                <div class="ionic-bundle__option-body">
                  <p class="ionic-bundle__option-title">{{ block.settings.title }}</p>
                  <span class="ionic-bundle__option-price-current">{{ variant.price | money }}</span>
                  {%- if variant.compare_at_price > variant.price -%}
                    <span class="ionic-bundle__option-price-compare">{{ variant.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
              </label>
            {%- else -%}
              {%- for variant in target_product.variants -%}
                <label
                  class="ionic-bundle__option{% if forloop.first %} is-selected{% endif %}"
                  for="ionic-bundle-auto-{{ section.id }}-{{ forloop.index }}"
                >
                  <input
                    type="radio"
                    id="ionic-bundle-auto-{{ section.id }}-{{ forloop.index }}"
                    name="id"
                    value="{{ variant.id }}"
                    {% if forloop.first %}checked{% endif %}
                  >
                  <div class="ionic-bundle__radio-wrap">
                    <span class="ionic-bundle__radio"></span>
                  </div>
                  <div class="ionic-bundle__option-img-wrap">
                    {%- if variant.featured_image -%}
                      <img class="ionic-bundle__option-img"
                        src="{{ variant.featured_image | image_url: width: 200 }}"
                        alt="{{ variant.title }}" width="200" height="80" loading="lazy">
                    {%- elsif target_product.featured_image -%}
                      <img class="ionic-bundle__option-img"
                        src="{{ target_product.featured_image | image_url: width: 200 }}"
                        alt="{{ variant.title }}" width="200" height="80" loading="lazy">
                    {%- endif -%}
                  </div>
                  <div class="ionic-bundle__option-body">
                    <p class="ionic-bundle__option-title">{{ variant.title }}</p>
                    <span class="ionic-bundle__option-price-current">{{ variant.price | money }}</span>
                    {%- if variant.compare_at_price > variant.price -%}
                      <span class="ionic-bundle__option-price-compare">{{ variant.compare_at_price | money }}</span>
                    {%- endif -%}
                  </div>
                </label>
              {%- endfor -%}
            {%- endfor -%}
          </div>

          <button type="submit" class="ionic-bundle__cta">
            {{ section.settings.btn_label }}
          </button>
        </form>

        {%- if section.settings.guarantee_text != blank -%}
          <p class="ionic-bundle__guarantee">{{ section.settings.guarantee_text }}</p>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<script>
(function(){
  var wrap = document.getElementById('ionic-bundle-options-{{ section.id }}');
  if (!wrap) return;
  wrap.addEventListener('click', function(e){
    var opt = e.target.closest('.ionic-bundle__option');
    if (!opt) return;
    wrap.querySelectorAll('.ionic-bundle__option').forEach(function(o){ o.classList.remove('is-selected'); });
    opt.classList.add('is-selected');
    var radio = opt.querySelector('input[type="radio"]');
    if (radio) radio.checked = true;
  });

  // Thumbnail carousel
  var thumbs = document.getElementById('ionic-bundle-thumbs-{{ section.id }}');
  var hero = document.getElementById('ionic-bundle-hero-{{ section.id }}');
  if (thumbs && hero) {
    thumbs.addEventListener('click', function(e){
      var thumb = e.target.closest('.ionic-bundle__thumb');
      if (!thumb || !thumb.dataset.src) return;
      thumbs.querySelectorAll('.ionic-bundle__thumb').forEach(function(t){ t.classList.remove('is-active'); });
      thumb.classList.add('is-active');
      hero.src = thumb.dataset.src;
    });
  }
})();
</script>

{% schema %}
{
  "name": "Ionic – Bundle Picker",
  "class": "index-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto (opcional, usa el producto actual si se deja vacío)"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Imagen principal (columna izquierda)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "ELIGE TU PAQUETE"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto del botón",
      "default": "AGREGAR AL CARRITO"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Texto de garantía bajo el botón",
      "default": "🔒 Pago seguro · Garantía de devolución de dinero · Envío rápido"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "selected_color",
      "label": "Color de opción seleccionada",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Color del precio de oferta",
      "default": "#2a9d4e"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Color de fondo del botón",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Color de texto del botón",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Color de fondo del badge",
      "default": "#e63737"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Color de texto del badge",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño del título",
      "min": 18, "max": 60, "step": 2,
      "default": 36, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Relleno superior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Relleno inferior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "option",
      "name": "Opción de paquete",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título de la opción",
          "default": "1 Unidad"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge (ej: MÁS POPULAR)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen del paquete"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ionic – Bundle Picker",
      "blocks": [
        {
          "type": "option",
          "settings": {
            "title": "1 Unidad – Purificador Iónico"
          }
        },
        {
          "type": "option",
          "settings": {
            "title": "2 Unidades – Purificador Iónico",
            "badge": "MÁS POPULAR"
          }
        },
        {
          "type": "option",
          "settings": {
            "title": "4 Unidades – Purificador Iónico",
            "badge": "MEJOR VALOR"
          }
        }
      ]
    }
  ]
}
{% endschema %}
