{{ 'scrolling-images.css' | asset_url | stylesheet_tag }}

<div class="scrolling-images section-spacing{% if section.settings.disable_top %} section-spacing--disable-top{% endif %}{% if section.settings.disable_bottom %} section-spacing--disable-bottom{% endif %}" id="scrolling-images-{{ section.id }}">
  <div class="scrolling-images--inner scrolling-images--{{ section.settings.align }} direction-{{ section.settings.direction }} scrolling-images--spacing-{{ section.settings.spacing }}"
    style="--marquee-speed: {{ section.settings.speed }}s">

    {%- assign repeats = section.settings.repeats | default: 2 -%}
    {%- if repeats < 1 -%}{%- assign repeats = 1 -%}{%- endif -%}

    {%- for r in (1..repeats) -%}
      <div>
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <div class="scrolling-images--item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a class="scrolling-images--link" href="{{ block.settings.link }}">
              {%- endif -%}

              <div class="scrolling-images--image aspect-ratio aspect-ratio--square" style="--ratio-percent: {{ block.settings.ratio_percent }}%; width: {{ block.settings.width }}px;">
                {%- if block.settings.image != blank -%}
                  {%- assign img_url = block.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
                  <img
                    class="lazyload"
                    data-src="{{ img_url }}"
                    data-widths="[360, 540, 720, 900, 1080, 1280, 1600]"
                    data-aspectratio="{{ block.settings.image.aspect_ratio }}"
                    data-sizes="auto"
                    alt="{{ block.settings.image.alt | escape }}"
                    style="object-position: {{ block.settings.focal_point }};" />
                {%- endif -%}
              </div>

              {%- if block.settings.caption != blank -%}
                <div class="scrolling-images--content"><h6>{{ block.settings.caption }}</h6></div>
              {%- endif -%}

              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Carrusel de imágenes",
  "class": "section-scrolling-images",
  "settings": [
    {
      "type": "checkbox",
      "id": "disable_top",
      "label": "Desactivar espacio superior",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "disable_bottom",
      "label": "Desactivar espacio inferior",
      "default": true
    },
    {
      "type": "select",
      "id": "align",
      "label": "Alineación vertical",
      "default": "center",
      "options": [
        { "value": "top", "label": "Arriba" },
        { "value": "center", "label": "Centro" },
        { "value": "bottom", "label": "Abajo" }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Dirección",
      "default": "left",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "right", "label": "Derecha" }
      ]
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Velocidad",
      "default": 20
    },
    {
      "type": "select",
      "id": "spacing",
      "label": "Espaciado entre items",
      "default": "small",
      "options": [
        { "value": "small", "label": "Pequeño" },
        { "value": "medium", "label": "Medio" },
        { "value": "large", "label": "Grande" }
      ]
    },
    {
      "type": "range",
      "id": "repeats",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Repeticiones (loop)",
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Imagen",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (opcional)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Texto (opcional)",
          "default": "Coming Soon"
        },
        {
          "type": "range",
          "id": "width",
          "label": "Ancho del item",
          "min": 120,
          "max": 700,
          "step": 10,
          "unit": "px",
          "default": 500
        },
        {
          "type": "range",
          "id": "ratio_percent",
          "label": "Relación (alto en %)",
          "min": 40,
          "max": 140,
          "step": 1,
          "unit": "%",
          "default": 100
        },
        {
          "type": "select",
          "id": "focal_point",
          "label": "Enfoque de imagen",
          "default": "50% 50%",
          "options": [
            { "value": "50% 50%", "label": "Centro" },
            { "value": "50% 0%", "label": "Arriba" },
            { "value": "50% 100%", "label": "Abajo" },
            { "value": "0% 50%", "label": "Izquierda" },
            { "value": "100% 50%", "label": "Derecha" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carrusel de imágenes",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
