{% comment %} ba-16458925 – zpa-image-text-2-233 {% endcomment %}

<style>
  .ionic-image-text-2 {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }
  .ionic-image-text-2__inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.gap }}px;
    align-items: center;
  } 
  .ionic-image-text-2__img-col img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ section.settings.img_radius }}px;
    object-fit: cover;
  }
  .ionic-image-text-2__img-col {
    border-radius: {{ section.settings.img_radius }}px;
    overflow: hidden;
  }
  .ionic-image-text-2__text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .ionic-image-text-2__eyebrow {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.accent_color }};
    margin: 0 0 12px;
  }
  .ionic-image-text-2__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 900;
    line-height: 1.15;
    margin: 0 0 20px;
    color: {{ section.settings.text_color }};
    {%- if section.settings.uppercase %}text-transform: uppercase;{%- endif %}
  }
  .ionic-image-text-2__body {
    font-size: {{ section.settings.body_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.7;
    margin: 0 0 28px;
  }
  .ionic-image-text-2__body p { margin: 0 0 12px; }
  .ionic-image-text-2__body p:last-child { margin-bottom: 0; }
  .ionic-image-text-2__steps {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ionic-image-text-2__step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .ionic-image-text-2__step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
    font-weight: 900;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ionic-image-text-2__step-text {
    font-size: 0.95rem;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
    padding-top: 6px;
  }
  .ionic-image-text-2__step-title {
    font-weight: 800;
    display: block;
    margin-bottom: 2px;
  }
  @media (max-width: 768px) {
    .ionic-image-text-2__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .ionic-image-text-2__heading {
      font-size: {{ section.settings.heading_size | times: 0.65 | round }}px;
    }
    {%- if section.settings.layout == 'image_right' %}
    .ionic-image-text-2__img-col { order: -1; }
    {%- endif %}
  }
</style>

<div class="ionic-image-text-2">
  <div class="ionic-image-text-2__inner" style="direction: {% if section.settings.layout == 'image_right' %}ltr{% else %}ltr{% endif %};">

    {%- if section.settings.layout == 'image_left' -%}
      <div class="ionic-image-text-2__img-col">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy">
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="ionic-image-text-2__text-col">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ionic-image-text-2__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ionic-image-text-2__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="ionic-image-text-2__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="ionic-image-text-2__steps">
          {%- for block in section.blocks -%}
            <li class="ionic-image-text-2__step" {{ block.shopify_attributes }}>
              <div class="ionic-image-text-2__step-num">{{ forloop.index }}</div>
              <div class="ionic-image-text-2__step-text">
                {%- if block.settings.title != blank -%}
                  <span class="ionic-image-text-2__step-title">{{ block.settings.title }}</span>
                {%- endif -%}
                {{ block.settings.description }}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- if section.settings.layout == 'image_right' -%}
      <div class="ionic-image-text-2__img-col">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy">
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Ionic – Imagen + Texto 2",
  "class": "index-section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Posición de la imagen",
      "default": "image_right",
      "options": [
        { "value": "image_left",  "label": "Imagen a la izquierda" },
        { "value": "image_right", "label": "Imagen a la derecha" }
      ]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "range",
      "id": "img_radius",
      "label": "Radio de la imagen",
      "min": 0, "max": 40, "step": 2,
      "default": 12, "unit": "px"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "CÓMO FUNCIONA EN 3 PASOS"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Título en mayúsculas",
      "default": true
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Texto introductorio",
      "default": "<p>El purificador iónico trabaja de forma silenciosa y eficiente para mantenerte saludable.</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño del título",
      "min": 18, "max": 72, "step": 2,
      "default": 40, "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Tamaño del texto",
      "min": 12, "max": 24, "step": 1,
      "default": 16, "unit": "px"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacio entre columnas",
      "min": 20, "max": 100, "step": 4,
      "default": 60, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Relleno superior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Relleno inferior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Paso / Punto",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título del paso",
          "default": "Paso"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripción",
          "default": "Descripción del paso aquí."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ionic – Imagen + Texto 2",
      "blocks": [
        { "type": "step", "settings": { "title": "Ionización del aire", "description": "El dispositivo libera iones negativos que se adhieren a los contaminantes del aire." } },
        { "type": "step", "settings": { "title": "Atracción de partículas", "description": "Los iones cargan las partículas peligrosas como virus, bacterias y polvo." } },
        { "type": "step", "settings": { "title": "Aire limpio", "description": "Las partículas cargadas caen al suelo, alejándose del aire que respiras." } }
      ]
    }
  ]
}
{% endschema %}
