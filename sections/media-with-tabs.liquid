{{ 'media-with-tabs.css' | asset_url | stylesheet_tag }}

<div class="row">
  <div class="small-12 columns">
    <media-with-tabs
      class="media-with-tabs media-with-tabs--transparent-{{ section.settings.transparent }} desktop-height-{{ section.settings.desktop_height }} {{ section.settings.layout }} section-spacing"
      style="--color-bg: {{ section.settings.color_bg }}; --color-text:{{ section.settings.color_text }}; --color-border: {{ section.settings.color_border }}; --color-accent: {{ section.settings.color_accent }}; --mobile-height: {{ section.settings.mobile_height }}px;">

      <div class="media-with-tabs--media" tabindex="0">
        {%- for block in section.blocks -%}
          <div class="carousel__slide{% if forloop.first %} is-selected{% endif %}" {{ block.shopify_attributes }}>
            <div class="media-with-tabs--media--container" style="padding-bottom: var(--mobile-height);">
              {%- if block.settings.image != blank -%}
                {%- assign img_url = block.settings.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
                <img
                  class="lazyload"
                  data-src="{{ img_url }}"
                  data-widths="[360, 540, 720, 900, 1080, 1280]"
                  data-aspectratio="{{ block.settings.image.aspect_ratio }}"
                  data-sizes="auto"
                  alt="{{ block.settings.image.alt | escape }}"
                  style="object-position: {{ block.settings.focal_point }};" />
              {%- else -%}
                <div class="thb-placeholder"></div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="media-with-tabs--content">
        {%- if section.settings.badge_text != blank -%}
          <div>
            <span class="inline-badge" style="--badge-bg: {{ section.settings.badge_bg }};--badge-text: {{ section.settings.badge_text_color }}">{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h3 class="h2">{{ section.settings.heading }}</h3>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          <div class="media-with-tabs--tab{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}">
            <button class="media-with-tabs--button" type="button">{{ block.settings.tab_title }}</button>
            <div class="media-with-tabs--text">{{ block.settings.tab_text }}</div>
          </div>
        {%- endfor -%}
      </div>

    </media-with-tabs>
  </div>
</div>

<script src="{{ 'media-with-tabs.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Galería con tabs",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Orden",
      "default": "text_first",
      "options": [
        { "value": "image_first", "label": "Imagen primero" },
        { "value": "text_first", "label": "Texto primero" }
      ]
    },
    {
      "type": "checkbox",
      "id": "transparent",
      "label": "Fondo transparente",
      "default": false
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Altura en escritorio",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Automática" }
      ]
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200,
      "max": 800,
      "step": 10,
      "unit": "px",
      "label": "Altura en móvil",
      "default": 500
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Color de fondo",
      "default": "#2c2d2e"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Color de texto",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Color de borde",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_accent",
      "label": "Color de acento",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texto del badge",
      "default": "Innovador"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Fondo del badge",
      "default": "#eb4f45"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Texto del badge (color)",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Características del producto"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Descripción",
      "default": "<p>Escribe aquí la descripción del producto.</p>"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "select",
          "id": "focal_point",
          "label": "Enfoque de imagen",
          "default": "50% 50%",
          "options": [
            { "value": "50% 50%", "label": "Centro" },
            { "value": "50% 0%", "label": "Arriba" },
            { "value": "50% 100%", "label": "Abajo" },
            { "value": "0% 50%", "label": "Izquierda" },
            { "value": "100% 50%", "label": "Derecha" }
          ]
        },
        {
          "type": "text",
          "id": "tab_title",
          "label": "Título del tab",
          "default": "Título del tab"
        },
        {
          "type": "textarea",
          "id": "tab_text",
          "label": "Texto del tab",
          "default": "Texto descriptivo del tab."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Galería con tabs",
      "blocks": [
        { "type": "tab" },
        { "type": "tab" },
        { "type": "tab" }
      ]
    }
  ]
}
{% endschema %}
