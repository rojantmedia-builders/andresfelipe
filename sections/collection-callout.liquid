{{ 'layered-images-with-text.css' | asset_url | stylesheet_tag }}

{%- if section.settings.divider -%}<div class="section--divider">{%- endif -%}

<div class="index-section section-layered-images">
  <div class="page-width">

    <div class="layered-images-with-text {% if section.settings.layout == 'text_first' %}text_first{% endif %}">

      {%- comment -%} ── LEFT: Layered Images ── {%- endcomment -%}
      <div class="layered-images-with-text__inner layered-images-with-text__image">
        <div class="layered-images-with-text__image-media-container">
          <div class="layered-images-with-text__image-media-container-inner">

            {%- comment -%} Main image {%- endcomment -%}
            <div class="layered-images-with-text__image-media aspect-ratio aspect-ratio--{{ section.settings.image_ratio }}">
              <div class="layered-images-media">
                {%- if section.settings.image_1 != blank -%}
                  {{
                    section.settings.image_1
                    | image_url: width: 800
                    | image_tag: loading: 'lazy', alt: section.settings.image_1.alt
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
            </div>

            {%- comment -%} Image 2 — bottom left {%- endcomment -%}
            {%- if section.settings.image_2 != blank -%}
              <div class="layered-images-with-text__image-media aspect-ratio aspect-ratio--{{ section.settings.image_ratio }} layered-image-2">
                <div class="layered-images-media">
                  {{
                    section.settings.image_2
                    | image_url: width: 500
                    | image_tag: loading: 'lazy', alt: section.settings.image_2.alt
                  }}
                </div>
              </div>
            {%- endif -%}

            {%- comment -%} Image 3 — top right {%- endcomment -%}
            {%- if section.settings.image_3 != blank -%}
              <div class="layered-images-with-text__image-media aspect-ratio aspect-ratio--{{ section.settings.image_ratio }} layered-image-3">
                <div class="layered-images-media">
                  {{
                    section.settings.image_3
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', alt: section.settings.image_3.alt
                  }}
                </div>
              </div>
            {%- endif -%}

          </div>
        </div>
      </div>

      {%- comment -%} ── RIGHT: Text ── {%- endcomment -%}
      <div class="layered-images-with-text__inner layered-images-with-text__content">
        <div class="layered-images-with-text__content--inner">

          {%- if section.settings.subtitle != blank -%}
            <span class="layered-images-with-text__subtitle">{{ section.settings.subtitle }}</span>
          {%- endif -%}

          {%- if section.settings.title != blank -%}
            <h2 class="layered-images-with-text__heading">{{ section.settings.title }}</h2>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="rte">{{ section.settings.text }}</div>
          {%- endif -%}

          {%- if section.settings.cta_text1 != blank -%}
            <a href="{{ section.settings.cta_link1 }}" class="btn{% if section.settings.cta_text2 != blank %} btn--no-animate{% endif %}">
              {{ section.settings.cta_text1 }}
            </a>
          {%- endif -%}

          {%- if section.settings.cta_text2 != blank -%}
            <a href="{{ section.settings.cta_link2 }}" class="btn btn--no-animate">
              {{ section.settings.cta_text2 }}
            </a>
          {%- endif -%}

        </div>
      </div>

    </div>
  </div>
</div>

{%- if section.settings.divider -%}</div>{%- endif -%}

{% schema %}
{
  "name": "Collection callout",
  "class": "index-section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Main image (center)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (bottom left)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (top right)"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "default": "portrait",
      "options": [
        { "value": "portrait",  "label": "Portrait (4:5)" },
        { "value": "square",    "label": "Square (1:1)" },
        { "value": "landscape", "label": "Landscape (4:3)" }
      ]
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "EFFORTLESS PURIFICATION, MAXIMUM RESULTS"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why You'll Love the Ionic Purifier"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<ul><li><strong>Filterless Design</strong><br>Say goodbye to costly filter replacements—clean air without the hassle.</li><li><strong>Energy Efficient</strong><br>Keeps your air clean while saving on energy bills.</li></ul>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "cta_text1",
      "label": "Button #1 text"
    },
    {
      "type": "url",
      "id": "cta_link1",
      "label": "Button #1 link"
    },
    {
      "type": "text",
      "id": "cta_text2",
      "label": "Button #2 text"
    },
    {
      "type": "url",
      "id": "cta_link2",
      "label": "Button #2 link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "image_first",
      "options": [
        { "value": "image_first", "label": "Images left, text right" },
        { "value": "text_first",  "label": "Text left, images right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "Show section divider",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Collection callout"
    }
  ]
}
{% endschema %}
