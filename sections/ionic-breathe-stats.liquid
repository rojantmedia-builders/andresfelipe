{% comment %} ba-16458917 + ba-16458918 – zpa-plain-text-002 {% endcomment %}

<style>
  .ionic-breathe-stats {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }
  .ionic-breathe-stats__inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ section.settings.text_align }};
  }
  .ionic-breathe-stats__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 900;
    line-height: 1.15;
    margin: 0 0 28px;
    color: {{ section.settings.text_color }};
  }
  .ionic-breathe-stats__body {
    font-size: {{ section.settings.body_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.7;
    margin: 0;
  }
  .ionic-breathe-stats__body p {
    margin: 0 0 14px;
  }
  .ionic-breathe-stats__body p:last-child {
    margin-bottom: 0;
  }
  @media (max-width: 768px) {
    .ionic-breathe-stats__heading {
      font-size: {{ section.settings.heading_size | times: 0.6 | round }}px;
    }
  }
</style>

<div class="ionic-breathe-stats">
  <div class="ionic-breathe-stats__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="ionic-breathe-stats__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="ionic-breathe-stats__body">{{ section.settings.body }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{ 
  "name": "Ionic – Estadísticas Aire",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Respiras 10.600 Litros De Aire Cada Día. ¡Eso Es Mucho Aire!"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Texto del cuerpo",
      "default": "<p>La Agencia de Protección Ambiental ha clasificado la calidad del aire interior como uno de los peligros más preocupantes que enfrentamos a diario. La EPA estima que el aire de nuestros hogares tiene casi cinco veces más contaminantes que el aire exterior. Nuestras casas, oficinas y autos contienen químicos, gases y partículas en el aire que pueden ser devastadores para nuestra salud.</p><p>Probamos decenas de purificadores de aire, pero todos fallaron en lo más importante: proporcionar aire limpio. El dicho reza: \"Si quieres que algo salga bien, hazlo tú mismo.\" Pues exactamente eso fue lo que hicimos.</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alineación del texto",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right",  "label": "Derecha" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Ancho máximo del contenido",
      "min": 480,
      "max": 1200,
      "step": 40,
      "default": 960,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño del título (escritorio)",
      "min": 24,
      "max": 80,
      "step": 2,
      "default": 52,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Tamaño del texto",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Relleno superior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Relleno inferior",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 72,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Ionic – Breathe Stats Text"
    }
  ]
}
{% endschema %}
