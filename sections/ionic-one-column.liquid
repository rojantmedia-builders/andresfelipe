{% comment %} ba-16458921 – zpa-layout-one-column-173 {% endcomment %}

<style>
  .ionic-one-column {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    text-align: {{ section.settings.text_align }};
  }
  .ionic-one-column__inner {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  } 
  .ionic-one-column__eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: {{ section.settings.accent_color }};
    margin: 0 0 14px;
  }
  .ionic-one-column__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 900;
    line-height: 1.15;
    margin: 0 0 20px;
    color: {{ section.settings.text_color }};
    {%- if section.settings.uppercase_heading %}text-transform: uppercase;{%- endif %}
  }
  .ionic-one-column__body {
    font-size: {{ section.settings.body_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.7;
    margin: 0 0 28px;
  }
  .ionic-one-column__body p { margin: 0 0 12px; }
  .ionic-one-column__body p:last-child { margin-bottom: 0; }
  .ionic-one-column__stats {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 40px;
    margin-top: 40px;
  }
  .ionic-one-column__stat {
    text-align: center;
  }
  .ionic-one-column__stat-number {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
    color: {{ section.settings.text_color }};
    display: block;
  }
  .ionic-one-column__stat-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: {{ section.settings.text_color }};
    opacity: 0.75;
    margin-top: 6px;
  }
  @media (max-width: 768px) {
    .ionic-one-column__heading {
      font-size: {{ section.settings.heading_size | times: 0.65 | round }}px;
    }
    .ionic-one-column__stat-number { font-size: 2.2rem; }
  }
</style>

<div class="ionic-one-column">
  <div class="ionic-one-column__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ionic-one-column__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ionic-one-column__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="ionic-one-column__body">{{ section.settings.body }}</div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ionic-one-column__stats">
        {%- for block in section.blocks -%}
          <div class="ionic-one-column__stat" {{ block.shopify_attributes }}>
            <span class="ionic-one-column__stat-number">{{ block.settings.number }}</span>
            <span class="ionic-one-column__stat-label">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Ionic – Una Columna",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "El purificador de aire #1 en América"
    },
    {
      "type": "checkbox",
      "id": "uppercase_heading",
      "label": "Título en mayúsculas",
      "default": true
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Texto del cuerpo",
      "default": "<p>Describe aquí el contenido principal de esta sección.</p>"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento (eyebrow)",
      "default": "#1a1a1a"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Alineación",
      "default": "center",
      "options": [
        { "value": "left",   "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right",  "label": "Derecha" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Ancho máximo del contenido",
      "min": 480,
      "max": 1200,
      "step": 40,
      "default": 880,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Tamaño del título (escritorio)",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Tamaño del texto",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Relleno superior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Relleno inferior",
      "min": 0, "max": 120, "step": 4,
      "default": 72, "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estadística",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Número / cifra",
          "default": "200K+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Clientes satisfechos"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ionic – Una Columna",
      "blocks": [
        { "type": "stat", "settings": { "number": "200.000+", "label": "Clientes satisfechos" } },
        { "type": "stat", "settings": { "number": "99%",      "label": "Tasa de satisfacción" } },
        { "type": "stat", "settings": { "number": "2 años",   "label": "Garantía del fabricante" } }
      ]
    }
  ]
}
{% endschema %}
