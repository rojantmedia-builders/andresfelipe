        "q1": {
          "type": "question",
          "settings": {
            "question": "¿Funciona con baterías?",
            "answer": "<p>No. Debe permanecer conectado a una toma de corriente mediante el cable USB y el adaptador incluidos.</p>"
          }
        },
        "q2": {
          "type": "question",
          "settings": {
            "question": "¿Necesita filtros de reemplazo?",
            "answer": "<p>No. A diferencia de los purificadores HEPA tradicionales, el Iónico no requiere filtros costosos. Solo necesitas limpiar el colector de polvo con un paño seco cada pocas semanas.</p>"
          }
        },
        "q3": {
          "type": "question",
          "settings": {
            "question": "¿Cuánto espacio cubre una unidad?",
            "answer": "<p>El Iónico cubre eficazmente espacios de hasta 500 pies cuadrados (aproximadamente 46 metros cuadrados).</p>"
          }
        },
        "q4": {
          "type": "question",
          "settings": {
            "question": "¿Funciona fuera de EE.UU.?",
            "answer": "<p>Sí. El Iónico es compatible con la mayoría de sistemas eléctricos del mundo (100-240V).</p>"
          }
        },
        "q5": {
          "type": "question",
          "settings": {
            "question": "¿Es seguro para niños y mascotas?",
            "answer": "<p>Sí. El Iónico es completamente seguro para toda la familia. No emite ozono dañino ni produce ruido.</p>"
          }
        }
